# LangSmith 配置
# 如何获取 LangSmith API Key:
# 1. 访问 https://www.langchain.com/langsmith
# 2. 登录或创建账户
# 3. 进入 Settings -> API Keys
# 4. 创建新的 API Key 或使用现有密钥
# 5. 将生成的密钥复制到下方 LANGCHAIN_API_KEY 字段

# 启用 LangSmith 跟踪
LANGCHAIN_TRACING_V2=true

# LangSmith API 密钥
LANGCHAIN_API_KEY=A


# LangSmith 项目名称
LANGCHAIN_PROJECT=test_rag_evaluation

# RAG 应用 API URL
RAG_APP_API_URL=http://localhost:8000
